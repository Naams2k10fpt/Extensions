{
  "manifest_version": 3,
  "name": "Manga Translator AI",
  "version": "1.0",
  "description": "Dịch manga trực tiếp trên trang web sử dụng công nghệ OCR và dịch thuật tiên tiến từ Gemini AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "commands": {
    "activate-translation": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Kích hoạt chế độ chọn vùng dịch manga"
    }
  }
}
