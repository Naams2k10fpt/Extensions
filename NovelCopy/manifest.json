{
  "manifest_version": 3,
  "name": "NovelCopy",
  "version": "1.0.0",
  "description": "Copy novel contents (Title, Volume, Chapter, Link, Illustrations) as clean Markdown.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
